---
import { socials } from "../data/site";
interface Props {
  class?: string;
}
const { class: cls = "" } = Astro.props;

const icons: Record<string, string> = {
  X: `<path d="M17.5 3h2.6l-5.7 6.5L21 21h-4.9l-3.8-5-4.4 5H3.3l6.1-7L3 3h5l3.5 4.6L17.5 3Zm-.9 16h1.4L8 4.4H6.5L16.6 19Z"/>`,
  Instagram: `<rect x="3.5" y="3.5" width="17" height="17" rx="5" fill="none" stroke="currentColor" stroke-width="1.8"/><circle cx="12" cy="12" r="3.6" fill="none" stroke="currentColor" stroke-width="1.8"/><circle cx="17" cy="7" r="1.1"/>`,
  Facebook: `<path d="M13.5 21v-7h2.3l.4-2.8h-2.7V9.3c0-.8.3-1.4 1.5-1.4h1.3V5.4c-.6-.1-1.4-.2-2.2-.2-2.2 0-3.7 1.3-3.7 3.8v2.2H8.2V14h2.4v7h2.9Z"/>`,
  Threads: `<path d="M12 21c-4.6 0-7.5-3.2-7.5-9S7.4 3 12 3c3 0 5.2 1.3 6.3 3.7l-2 1c-.7-1.6-2.1-2.4-4.3-2.4-3.3 0-5.2 2.3-5.2 6.7s1.9 6.8 5.2 6.8c2.4 0 3.9-1.1 3.9-2.9 0-1.6-1.3-2.6-3.5-2.6-1.2 0-2 .5-2 1.4 0 .6.4 1 1.1 1 .2 0 .4 0 .5-.1l.3 1.7c-.3.1-.7.2-1.1.2-1.8 0-3-1.1-3-2.8 0-2 1.7-3.2 4.2-3.2 3.3 0 5.5 1.8 5.5 4.5C17.7 19.2 15.4 21 12 21Z"/>`,
};
---

<ul class={`flex items-center gap-5 ${cls}`}>
  {
    socials.map((s) => (
      <li>
        <a
          href={s.href}
          target="_blank"
          rel="noopener noreferrer"
          class="block text-ink transition hover:text-muted"
          aria-label={s.label}
        >
          <svg
            width="22"
            height="22"
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
            set:html={icons[s.label] ?? ""}
          />
        </a>
      </li>
    ))
  }
</ul>
