---
import { site } from "../data/site";
import Logo from "./Logo.astro";
import SocialLinks from "./SocialLinks.astro";
const year = new Date().getFullYear();
---

<footer class="mt-24 border-t border-line">
  <div class="mx-auto max-w-6xl px-5 py-14">
    <div class="flex flex-col gap-12 md:flex-row md:justify-between">
      <!-- vlevo: logo + citát -->
      <div class="max-w-sm">
        <Logo />
        <p class="mt-6 font-heading text-xl font-extrabold text-ink">
          {site.quote}
        </p>
      </div>

      <!-- vpravo: sloupce odkazů -->
      <div class="flex gap-16 text-sm">
        <div>
          <h3 class="mb-4 text-xs font-bold tracking-wider text-muted uppercase">
            Stránky
          </h3>
          <ul class="space-y-3">
            <li><a class="text-ink hover:text-muted" href="/o-mne">O mně</a></li>
            <li>
              <a class="text-ink hover:text-muted" href="/kategorie">Kategorie</a>
            </li>
            <li>
              <a class="text-ink hover:text-muted" href="/kalendar">Kalendář</a>
            </li>
          </ul>
        </div>
        <div>
          <h3 class="mb-4 text-xs font-bold tracking-wider text-muted uppercase">
            Odkazy
          </h3>
          <ul class="space-y-3">
            <li>
              <a class="text-ink hover:text-muted" href="/kontakt">Kontakt</a>
            </li>
            <li>
              <a class="text-ink hover:text-muted" href="/soukromi"
                >Ochrana osobních údajů</a
              >
            </li>
          </ul>
        </div>
      </div>
    </div>

    <div
      class="mt-12 flex flex-col gap-4 border-t border-line pt-6 sm:flex-row sm:items-center sm:justify-between"
    >
      <p class="text-xs text-muted">
        © {year} {site.title} — Vytvořeno s ♥ a během
      </p>
      <SocialLinks />
    </div>
  </div>
</footer>
