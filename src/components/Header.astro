---
import { nav } from "../data/site";
import Logo from "./Logo.astro";
const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/" ? path === "/" : path.startsWith(href);
---

<header class="sticky top-0 z-40 bg-white/90 backdrop-blur">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-5 py-4">
    <a href="/" aria-label="Domů"><Logo /></a>

    <div class="flex items-center gap-2">
      <!-- Desktop menu -->
      <nav class="hidden md:block">
        <ul class="flex items-center gap-1 text-sm font-bold">
          {
            nav.map((item) => (
              <li>
                <a
                  href={item.href}
                  class={`rounded-full px-3.5 py-2 transition hover:bg-surface ${
                    isActive(item.href) ? "text-ink" : "text-muted"
                  }`}
                >
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <a
        href="/kategorie"
        aria-label="Hledat / kategorie"
        class="flex h-11 w-11 items-center justify-center rounded-full bg-surface text-ink transition hover:bg-line"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
          stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <circle cx="11" cy="11" r="7"></circle>
          <path d="m21 21-4.3-4.3"></path>
        </svg>
      </a>

      <!-- Hamburger jen na mobilu -->
      <button
        id="menu-toggle"
        aria-label="Menu"
        aria-expanded="false"
        class="flex h-11 w-11 items-center justify-center rounded-full bg-surface text-ink transition hover:bg-line md:hidden"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
          stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <path d="M4 7h16M4 12h16M4 17h16"></path>
        </svg>
      </button>
    </div>
  </div>

  <!-- rozbalovací menu (mobil) -->
  <nav id="menu-panel" class="hidden border-t border-line bg-white md:hidden">
    <ul class="mx-auto max-w-6xl px-5 py-3 text-sm font-bold">
      {
        nav.map((item) => (
          <li>
            <a
              href={item.href}
              class={`block rounded-xl px-3 py-2.5 transition hover:bg-surface ${
                isActive(item.href) ? "text-ink" : "text-muted"
              }`}
            >
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>

<script>
  const btn = document.getElementById("menu-toggle");
  const panel = document.getElementById("menu-panel");
  btn?.addEventListener("click", () => {
    const open = panel?.classList.toggle("hidden");
    btn.setAttribute("aria-expanded", open ? "false" : "true");
  });
</script>
