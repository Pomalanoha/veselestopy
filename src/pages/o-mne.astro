---
import BaseLayout from "../layouts/BaseLayout.astro";
import SocialLinks from "../components/SocialLinks.astro";
import { site } from "../data/site";

const img = (id: string, opts = "scale-down-to=1024&lossless=1") =>
  `https://framerusercontent.com/images/${id}.jpg?${opts}`;

// Střídavé bloky: obrázek + text (zig-zag jako na původním webu)
const blocks = [
  {
    image: img("AfsEFbYNQX0uUk631BwPrnQoJM"),
    alt: "Jan Veselý, MS Ricochet",
    imageLeft: true,
    paragraphs: [
      "Sport byl a vždy bude nedílnou součástí mého života. Už od útlého dětství jsem se aktivně věnoval různým sportům, počínaje národní házenou a atletikou v SK Jeseniova. Nicméně, mým hlavním sportem se stal squash, který mě naprosto pohltil.",
      "Sportovní duch se v naší rodině dědí z generace na generaci. Zvláštní místo v naší rodinné historii zaujímá můj dědeček, který v roce 1949 vyhrál Závod míru, což byl v té době obrovský sportovní úspěch.",
    ],
  },
  {
    image: img("6A4MtsO3UIsKUxnofsMvkt0I4", "lossless=1"),
    alt: "Dědeček – Závod míru",
    imageLeft: false,
    paragraphs: [
      "Ačkoli jsem se nevydal přesně v dědečkových šlépějích, sportovní vášeň mě provází celým životem. Po zkušenostech s různými sporty jsem se naplno oddal squashi a ricochetu. Ve squashi jsem v juniorských kategoriích dosáhl několika titulů Mistra České republiky a v ricochetu jsem se stal dokonce Mistrem světa v roce 2012, což je pro mě doposud jedinečný úspěch.",
    ],
  },
  {
    image: img("tNFBON400M89KfmygoORkEykuFU"),
    alt: "Jan Veselý, Lavaredo 50K",
    imageLeft: true,
    paragraphs: [
      "Moje squashová kariéra mě dovedla až k získání trenérské licence II. třídy a k 4. místu na Mistrovství České republiky ve squashi.",
      "Po ukončení profesionální squashové kariéry jsem se s nadšením vrhl na běh. Stále se snažím posouvat své limity a objevovat nové výzvy.",
    ],
  },
  {
    image: img("Wml6UGLdyWDd0PsWkOix18FVrM"),
    alt: "Jan Veselý, Kolo pro život",
    imageLeft: false,
    paragraphs: [
      "Kromě běhu jsem se občas zúčastnil i závodů na horských kolech v rámci seriálu Kolo pro život, kde se mi dokonce podařilo jeden závod na 32 km vyhrát.",
    ],
  },
];
---

<BaseLayout title="O mně">
  <!-- Hero -->
  <section class="relative overflow-hidden bg-surface">
    <span class="absolute top-10 left-[18%] h-1.5 w-1.5 rounded-full bg-zinc-300"></span>
    <span class="absolute top-24 right-[20%] h-1.5 w-1.5 rounded-full bg-zinc-300"></span>
    <span class="absolute bottom-12 left-[30%] h-1 w-1 rounded-full bg-zinc-300"></span>
    <div class="mx-auto max-w-6xl px-5 py-14 text-center">
      <img
        src={site.portrait}
        alt={site.author}
        class="mx-auto h-24 w-24 object-contain"
      />
      <h1 class="mt-5 font-heading text-2xl font-extrabold text-ink sm:text-3xl">
        Něco málo o mně
      </h1>
      <div class="mt-6 flex justify-center"><SocialLinks /></div>
    </div>
  </section>

  <!-- Střídavé bloky -->
  <div class="mx-auto max-w-5xl space-y-16 px-5 py-16 sm:space-y-24">
    {
      blocks.map((b) => (
        <section class="grid items-center gap-8 md:grid-cols-2 md:gap-12">
          <img
            src={b.image}
            alt={b.alt}
            loading="lazy"
            class={`w-full rounded-3xl border border-line object-cover ${
              b.imageLeft ? "" : "md:order-2"
            }`}
          />
          <div class={b.imageLeft ? "" : "md:order-1"}>
            {b.paragraphs.map((p) => (
              <p class="mb-4 text-lg leading-relaxed text-body last:mb-0">{p}</p>
            ))}
          </div>
        </section>
      ))
    }
  </div>
</BaseLayout>
