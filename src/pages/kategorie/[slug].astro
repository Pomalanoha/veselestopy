---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ArticleCard from "../../components/ArticleCard.astro";
import { categories, getCategory } from "../../data/categories";

export async function getStaticPaths() {
  return categories.map((c) => ({ params: { slug: c.slug } }));
}

const { slug } = Astro.params;
const cat = getCategory(slug!);
const articles = (
  await getCollection(
    "clanky",
    ({ data }) => !data.draft && data.categories.includes(slug!),
  )
).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title={cat?.title ?? "Kategorie"}>
  <section class="mx-auto max-w-3xl px-5 pt-14">
    <p class="text-sm font-semibold tracking-wide text-muted uppercase">
      Kategorie
    </p>
    <h1 class="mt-2 font-heading text-3xl font-extrabold text-ink sm:text-4xl">
      {cat?.title ?? slug}
    </h1>
    {cat?.description && <p class="mt-3 text-muted">{cat.description}</p>}

    {
      articles.length > 0 ? (
        <div class="mt-10 space-y-14">
          {articles.map((a) => (
            <ArticleCard article={a} />
          ))}
        </div>
      ) : (
        <p class="mt-10 text-muted">Zatím tu nejsou žádné články.</p>
      )
    }
  </section>
</BaseLayout>
