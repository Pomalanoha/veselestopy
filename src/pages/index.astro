---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import ArticleCard from "../components/ArticleCard.astro";
import Sidebar from "../components/Sidebar.astro";
import SocialLinks from "../components/SocialLinks.astro";
import { site } from "../data/site";

const all = (await getCollection("clanky", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
// hlavní článek: nejnovější ze "zaškrtnutých"; jinak nejnovější celkově
const featured = all.find((a) => a.data.featured) ?? all[0];
const rest = all.filter((a) => a.id !== featured?.id);
---

<BaseLayout>
  <!-- Hero – přes celou šířku -->
  <section class="relative overflow-hidden bg-surface">
    <span class="absolute top-12 left-[15%] h-1.5 w-1.5 rounded-full bg-zinc-300"></span>
    <span class="absolute top-28 right-[18%] h-1.5 w-1.5 rounded-full bg-zinc-300"></span>
    <span class="absolute bottom-16 left-[28%] h-1.5 w-1.5 rounded-full bg-zinc-300"></span>
    <span class="absolute right-[30%] bottom-24 h-1 w-1 rounded-full bg-zinc-300"></span>
    <span class="absolute top-1/2 left-[8%] h-1 w-1 rounded-full bg-zinc-300"></span>
    <span class="absolute top-20 right-[40%] h-1 w-1 rounded-full bg-zinc-300"></span>

    <div class="mx-auto max-w-6xl px-5 py-16 text-center">
      <img
        src={site.portrait}
        alt={site.author}
        class="mx-auto h-24 w-24 object-contain"
      />
      <h1 class="mx-auto mt-5 max-w-md font-heading text-2xl font-extrabold text-ink sm:text-3xl">
        {site.tagline}
      </h1>
      <div class="mt-6 flex justify-center">
        <SocialLinks />
      </div>
    </div>
  </section>

  <div class="mx-auto max-w-6xl px-5">
    <!-- Nový (hlavní) článek -->
    {
      featured && (
        <section class="pt-14">
          <p class="mb-6 text-xs font-bold tracking-widest text-muted uppercase">
            Nový článek
          </p>
          <ArticleCard article={featured} variant="featured" />
        </section>
      )
    }

    <hr class="mt-14 border-line" />

    <!-- Poslední články + sidebar -->
    <section class="pt-12 pb-4">
      <p class="mb-8 text-xs font-bold tracking-widest text-muted uppercase">
        Poslední články
      </p>
      <div class="grid gap-12 lg:grid-cols-3">
        <div class="lg:col-span-2">
          <div class="space-y-12">
            {
              rest.map((a, i) => (
                <div class="article-item" data-hidden={i >= 7 ? "true" : "false"}>
                  <ArticleCard article={a} />
                </div>
              ))
            }
            {
              rest.length === 0 && (
                <p class="text-muted">Zatím tu nejsou žádné další články.</p>
              )
            }
          </div>

          {
            rest.length > 7 && (
              <div class="mt-12 text-center">
                <button
                  id="load-more"
                  class="inline-flex items-center rounded-full border border-line px-6 py-3 text-sm font-bold text-ink transition hover:bg-surface"
                >
                  Načíst další
                </button>
              </div>
            )
          }
        </div>
        <Sidebar />
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .article-item[data-hidden="true"] {
    display: none;
  }
</style>

<script>
  const btn = document.getElementById("load-more");
  btn?.addEventListener("click", () => {
    const hidden = document.querySelectorAll(
      '.article-item[data-hidden="true"]',
    );
    [...hidden].slice(0, 5).forEach((el) => el.setAttribute("data-hidden", "false"));
    if (document.querySelectorAll('.article-item[data-hidden="true"]').length === 0) {
      btn.style.display = "none";
    }
  });
</script>

