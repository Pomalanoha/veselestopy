---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Stránka nenalezena">
  <section class="mx-auto max-w-2xl px-5 py-24 text-center">
    <p class="font-heading text-8xl font-extrabold text-ink sm:text-9xl">404</p>
    <p class="mx-auto mt-6 max-w-lg font-heading text-2xl font-extrabold text-ink">
      Obávám se, že jsi se odchýlil ze značené běžecké stezky.
    </p>
    <a
      href="/"
      class="mt-8 inline-flex items-center rounded-full bg-ink px-6 py-3 text-sm font-bold text-white transition hover:opacity-90"
    >
      Jít domů
    </a>
  </section>
</BaseLayout>
