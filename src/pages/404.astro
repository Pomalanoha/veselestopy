---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Stránka nenalezena">
  <section class="mx-auto max-w-3xl px-5 py-24 text-center">
    <p class="font-heading text-6xl font-extrabold text-ink">404</p>
    <h1 class="mt-4 font-heading text-2xl font-extrabold text-ink">
      Tahle stránka tu není
    </h1>
    <p class="mt-3 text-muted">Možná zaběhla špatným směrem.</p>
    <a
      href="/"
      class="mt-8 inline-flex items-center rounded-full border border-line px-4 py-2 text-sm font-semibold text-ink transition hover:bg-surface"
    >
      ← Zpět na úvod
    </a>
  </section>
</BaseLayout>
