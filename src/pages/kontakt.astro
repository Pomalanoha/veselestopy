---
import BaseLayout from "../layouts/BaseLayout.astro";
import SocialLinks from "../components/SocialLinks.astro";
import { email } from "../data/site";
---

<BaseLayout title="Kontakt">
  <section class="mx-auto max-w-2xl px-5 pt-14">
    <h1 class="font-heading text-3xl font-extrabold text-ink sm:text-4xl">
      Pojďme mluvit 🙂
    </h1>
    <p class="mt-4 text-muted">
      Pokud potřebuješ pomoc nebo máš nějaké dotazy, neváhej se na mě obrátit.
    </p>

    <div class="mt-6 flex flex-wrap items-center gap-4">
      <a
        href={`mailto:${email}`}
        class="inline-flex items-center rounded-full bg-ink px-5 py-2.5 text-sm font-bold text-white transition hover:opacity-90"
      >
        {email}
      </a>
      <SocialLinks />
    </div>

    <form id="contact-form" class="mt-10 space-y-4">
      <div class="grid gap-4 sm:grid-cols-2">
        <input
          name="name"
          type="text"
          required
          placeholder="Jméno"
          class="w-full rounded-2xl border border-line bg-white px-4 py-3 text-ink outline-none focus:border-ink"
        />
        <input
          name="email"
          type="email"
          placeholder="Email"
          class="w-full rounded-2xl border border-line bg-white px-4 py-3 text-ink outline-none focus:border-ink"
        />
      </div>
      <input
        name="subject"
        type="text"
        placeholder="Předmět"
        class="w-full rounded-2xl border border-line bg-white px-4 py-3 text-ink outline-none focus:border-ink"
      />
      <textarea
        name="message"
        rows="6"
        required
        placeholder="Zpráva"
        class="w-full rounded-2xl border border-line bg-white px-4 py-3 text-ink outline-none focus:border-ink"
      ></textarea>
      <button
        type="submit"
        class="inline-flex items-center rounded-full bg-ink px-6 py-3 text-sm font-bold text-white transition hover:opacity-90"
      >
        Odeslat
      </button>
    </form>
    <p class="mt-3 text-xs text-muted">
      Tlačítko otevře tvého e-mailového klienta. (Pro odesílání přímo z webu lze
      později napojit službu jako Formspree.)
    </p>
  </section>
</BaseLayout>

<script define:vars={{ email }}>
  const form = document.getElementById("contact-form");
  form?.addEventListener("submit", (e) => {
    e.preventDefault();
    const data = new FormData(form);
    const subject = encodeURIComponent(data.get("subject") || "Zpráva z webu");
    const body = encodeURIComponent(
      `Jméno: ${data.get("name")}\nEmail: ${data.get("email")}\n\n${data.get("message")}`,
    );
    window.location.href = `mailto:${email}?subject=${subject}&body=${body}`;
  });
</script>
